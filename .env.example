# ── Supabase Configuration ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── S3 Compatible Storage (iwinv) ────────────────────────────────────
S3_ENDPOINT=https://kr.object.iwinv.kr
S3_REGION=kr-standard
S3_ACCESS_KEY=your-access-key-here
S3_SECRET_KEY=your-secret-key-here
S3_AUDIO_BUCKET=audio.your-domain.com
S3_META_BUCKET=meta.your-domain.com

# ── Supabase S3 (마이그레이션용, 이관 완료 후 제거) ────────────────────
SUPABASE_S3_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=your-supabase-s3-access-key
SUPABASE_S3_SECRET_KEY=your-supabase-s3-secret-key

# ── Server Configuration ──────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── 암호화 키 (AES-256-GCM) ───────────────────────────────────────────────
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-key-here

# ── Phone Hash Secret (HMAC-SHA256, 049 call-level ownership) ──────────
# call fingerprint의 speakers_hash 생성에 사용. 시드 단계 고정 + M6+ 로테이션 정책.
# service_role만 접근. raw phone DB 저장 X, 로그 phone 박지 X.
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_HASH_SECRET=your-32-byte-hex-secret-here
